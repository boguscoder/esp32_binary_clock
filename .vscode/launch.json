{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "probe-rs-debug",
            "request": "launch",
            "name": "probe-rs dbg",
            "cwd": "${workspaceFolder}",
            "connectUnderReset": true,
            "chip": "ESP32C6",
            "flashingConfig": {
                "flashingEnabled": true,
                "verifyBeforeFlashing": true,
                "verifyAfterFlashing": true,
                "haltAfterReset": true
            },
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "./target/riscv32imac-unknown-none-elf/debug/binary-clock"
                }
            ]
        }
    ]
}